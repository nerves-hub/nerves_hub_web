<NervesHubWeb.Layouts.sidebar flash={@flash} current_scope={@current_scope} sidebar_tab={@sidebar_tab}>
  <div class="bg-surface-muted border-base-700 flex h-[56px] justify-end border-b"></div>

  <div class="h-0 flex-1 overflow-y-auto">
    <div class="border-base-700 flex h-[90px] items-center gap-4 border-b px-6 py-7 text-sm font-medium">
      <h1 class="text-xl leading-[30px] font-semibold text-neutral-50">Users</h1>
      <div class="mr-auto"></div>
      <.button type="link" navigate={~p"/org/#{@org}/settings/users/invite"} aria-label="Add new user">
        <.icon name="add" /> Add New User
      </.button>
    </div>

    <%= if !Enum.empty?(@invites) do %>
      <h2 class="px-4 py-2 text-base font-semibold text-neutral-50">Outstanding Invites</h2>
      <div class="listing">
        <table>
          <thead>
            <tr>
              <th>Email</th>
              <th>Invite Link</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <%= for invite <- @invites do %>
              <tr class="border-base-800 isolate border-b">
                <td class="text-base-400">{invite.email}</td>
                <td class="text-base-400">
                  <code class="bg-base-900 text-base-400 rounded px-2 py-1 text-xs">{Routes.account_url(@socket, :invite, invite.token)}</code>
                </td>
                <td :if={authorized?(:"org_user:invite:rescind", @current_scope)} class="text-base-400">
                  <button
                    class="bg-base-800 border-base-700 hover:bg-base-700 text-base-300 rounded border px-3 py-1.5 text-sm font-medium"
                    phx-click="rescind_invite"
                    phx-value-invite_token={invite.token}
                    data-confirm="Are you sure you want to rescind the invite?"
                  >
                    Rescind
                  </button>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <div class="listing">
      <table>
        <thead>
          <tr>
            <th>User name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Added on</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <%= for org_user <- @org_users do %>
            <tr class="border-base-800 isolate border-b">
              <td>
                <.link navigate={~p"/org/#{@org}/settings/users/#{org_user.user_id}/edit"} class="hover:text-base-100 text-base-300">
                  {org_user.user.name}
                </.link>
              </td>
              <td>{org_user.user.email}</td>
              <td class="text-base-400 capitalize">{org_user.role}</td>
              <td class="text-base-400">
                <div phx-hook="SimpleDate" id={"user-#{org_user.id}-date"} class="date-time">{org_user.user.inserted_at}</div>
              </td>
              <td :if={authorized?(:"org_user:delete", @current_scope) && org_user.user.id != @current_scope.user.id} class="text-right">
                <div class="flex justify-end gap-2">
                  <.link
                    navigate={~p"/org/#{@org}/settings/users/#{org_user.user_id}/edit"}
                    class="bg-base-800 border-base-700 hover:bg-base-700 text-base-300 rounded border px-3 py-1.5 text-sm font-medium"
                  >
                    Edit
                  </.link>
                  <button
                    :if={authorized?(:"org_user:delete", @current_scope)}
                    type="link"
                    class="bg-base-800 border-alert hover:bg-base-700 text-alert rounded border px-3 py-1.5 text-sm font-medium"
                    phx-click="delete_org_user"
                    phx-value-user_id={org_user.user_id}
                    data-confirm="Are you sure you want to remove this user? This can not be undone."
                  >
                    Delete
                  </button>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</NervesHubWeb.Layouts.sidebar>
