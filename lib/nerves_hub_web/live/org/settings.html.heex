<NervesHubWeb.Layouts.sidebar flash={@flash} current_scope={@current_scope} sidebar_tab={@sidebar_tab}>
  <div class="bg-surface-muted border-base-700 h-topbar flex justify-end border-b"></div>

  <div class="h-0 flex-1 overflow-y-auto">
    <div class="border-base-700 h-header flex items-center gap-4 border-b px-6 py-7 text-sm font-medium">
      <h1 class="text-base-50 text-xl leading-[30px] font-semibold">Organization Settings</h1>
    </div>

    <div class="max-w-[650px] px-6 py-4">
      <.form :let={f} id="update-organization-form" for={@form} phx-submit="update">
        <div class="mb-4">
          <label for="name_input" class="text-base-300 mb-2 block text-sm font-medium">
            Organization Name <span class="text-base-500 ml-2 text-xs">(Must be one word)</span>
          </label>
          {text_input(f, :name, class: "w-full px-3 py-2 text-sm bg-base-900 border border-base-700 rounded text-base-50 focus:outline-none focus:ring-2 focus:ring-focus-ring", id: "name_input")}
          <div class="text-alert-content mt-1 text-sm">{error_tag(f, :name)}</div>
        </div>

        <div class="flex gap-3">
          <.button style="primary" type="submit">
            Save Changes
          </.button>
        </div>
      </.form>

      <div class="border-base-700 mt-8 border-t pt-6">
        <h3 class="text-base-50 mb-3 text-base font-semibold">Danger Zone</h3>
        <p class="text-base-400 mb-4 text-sm">Once you delete an organization, there is no going back. Please be certain.</p>
        <.button style="danger" type="link" patch={~p"/org/#{@org}/settings/delete"}>
          Delete Organization
        </.button>
      </div>
    </div>
  </div>
</NervesHubWeb.Layouts.sidebar>
