<Layouts.auth flash={@flash}>
  <:title>
    Please confirm your email
  </:title>
  <div class="mt-8">
    <p class="text-base-300 mt-2 text-sm/6">
      Your new account was created successfully!
    </p>

    <p class="text-base-300 mt-2 text-sm/6">
      An email was sent to has been sent to <span class="text-neutral-50 underline">{@email}</span> with a link to confirm your account.
    </p>
  </div>
</Layouts.auth>
